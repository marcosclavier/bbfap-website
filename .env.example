# Sanity (CMS) — required for build-time content fetch and the Studio
# After creating your Sanity project at https://sanity.io/manage, copy the
# project id here. Dataset is "production" by default.
VITE_SANITY_PROJECT_ID=
VITE_SANITY_DATASET=production

# Required ONLY to run scripts/migrate-content.mjs (one-time migration).
# Generate at sanity.io/manage → API → Tokens with "Editor" rights.
# Delete the token after migration; do NOT commit it.
SANITY_WRITE_TOKEN=

# Optional override for the YouTube channel feed source.
# Falls back to the @BelangerBrosseau channel ID baked into scripts/lib/youtube.mjs.
YOUTUBE_CHANNEL_ID=

# Google reCAPTCHA v3 — protects the contact form (src/pages/ContactPage.jsx).
# Register a v3 site at https://www.google.com/recaptcha/admin
#   CAPTCHA_SITE_KEY   — public key, injected into the client by vite.config.js
#   CAPTCHA_SECRET_KEY — server-only, used by api/contact.js to verify the token
# In production, set BOTH in the Vercel project's Environment Variables.
CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_KEY=

# Existing keys (already in .env, unrelated to CMS)
# GEMINI_API_KEY=
# GEMINI_PROJECT_NAME=
# SPIDER_CLOUD_API_KEY=
